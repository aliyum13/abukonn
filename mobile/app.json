{
  "expo": {
    "name": "ABUkonn",
    "slug": "abukonn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "abukonn",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.abukonn.app"
    },
    "android": {
      "package": "com.abukonn.app",
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://abukonn-production.up.railway.app"
    }
  }
}
