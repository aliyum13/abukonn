# EAS uploads the project directory to build in the cloud. Without this it was
# packaging ~272MB — node_modules, build caches, the lot — which made the upload
# fail with ECONNRESET on anything less than a perfect connection.
#
# None of this is needed for the build: EAS installs dependencies itself from
# package.json + package-lock.json.

node_modules/
.expo/
dist/
web-build/
.git/

# Native folders are regenerated by prebuild during the build
android/
ios/

# Local secrets — must never leave the machine
*firebase-adminsdk*.json
.env
.env.*

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.log
npm-debug.log*

# Docs and tooling irrelevant to the build
README.md
AGENTS.md
CLAUDE.md
.claude/
